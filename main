local weapons = RS2:FindFirstChild("Weapons") or RS2:FindFirstChild("Guns") or RS2:FindFirstChild("GunStats")
local savedValues = {}

if not weapons then
	for _, v in pairs(RS2:GetChildren()) do
		task.wait()
		if v:IsA("Folder") and (v:FindFirstChild("AK47") or v:FindFirstChild("M4")) then
			weapons = v
			break
		end
	end
end

RS.Heartbeat:Connect(function()
	
	if ThirteenthTrigger == true then
	
		for _, plrs in pairs(game.Players:GetPlayers()) do

			if plrs.Name == game.Players.LocalPlayer.Name then continue end

			local char = plrs.Character or plrs.CharacterAdded:Wait()

			local head = char:FindFirstChild("Head")

			if head then
				head.Size = Vector3.new(6, 6, 6)
				head.Transparency = 0.5
				head.CanCollide = false
			end
		end
	else
		for _, plrs in pairs(game.Players:GetPlayers()) do
			local char = plrs.Character or plrs.CharacterAdded:Wait()
			local head = char:FindFirstChild("Head")
			if head then
				head.Size = Vector3.new(1, 1, 1)
				head.Transparency = 0
				head.CanCollide = true
			end
		end
	end
end)

RS.Heartbeat:Connect(function()
	if TwelvethTrigger == true then
		local target = mouse.Target
		if target and target.Parent then
			local humanoid = target.Parent:FindFirstChildOfClass("Humanoid")
			if humanoid and humanoid.Health > 0 then
				local targetPlayer = game.Players:GetPlayerFromCharacter(target.Parent)
				if targetPlayer then
					if teamCheck == true and game.Players.LocalPlayer.Team and targetPlayer.Team == game.Players.LocalPlayer.Team then
						return
					end
					task.wait()
					local VirtualInput = game:GetService("VirtualInputManager")
					VirtualInput:SendMouseButtonEvent(0, 0, 0, true, game, 1)
					task.wait()
					VirtualInput:SendMouseButtonEvent(0, 0, 0, false, game, 1)
				end
			end
		end
	end
end)

local function isVisible(part)
	if not wallCheck then return true end

	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	rayParams.FilterDescendantsInstances = {game.Players.LocalPlayer.Character}

	local origin = camera.CFrame.Position
	local direction = part.Position - origin
	local result = workspace:Raycast(origin, direction, rayParams)

	if result then
		return result.Instance:IsDescendantOf(part.Parent)
	end
	return true
end
local function getClosestEnemy()
	local closest = nil
	local shortestDist = math.huge
	local center = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)
	local myTeam = game.Players.LocalPlayer.Team

	for _, other in ipairs(game.Players:GetPlayers()) do
		local character = other.Character
		local myPlayer = game.Players.LocalPlayer

		if other ~= myPlayer and character then
			local humanoid = character:FindFirstChildOfClass("Humanoid")
			local isFriendly = (teamCheck and myTeam and other.Team == myTeam)

			if humanoid and humanoid.Health > 0 and not isFriendly then
				local targetPart = character:FindFirstChild("HeadHB") or character:FindFirstChild("Head")

				if targetPart then
					local screenPos, onScreen = camera:WorldToViewportPoint(targetPart.Position)

					if onScreen then
						local screenDist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
						local worldDist = (targetPart.Position - camera.CFrame.Position).Magnitude

						if screenDist <= aimbotfov and worldDist <= maxDistance and isVisible(targetPart) then
							if screenDist < shortestDist then
								shortestDist = screenDist
								closest = targetPart
							end
						end
					end
				end
			end
		end
	end

	return closest
end



local function Hitbox(stat)
	if stat == true then
		
	end
end

local function Aimbot(stat, mode)
	if stat == true and not NinthTrigger then
		NinthTrigger = true

		if mode == "rage" then
			smoothness = 1.5
			aimbotfov = 1000
			wallCheck = true
			TargetPart = "Head"
		elseif mode == "legit" then
			smoothness = 0.07
			aimbotfov = 20
			wallCheck = true
			TargetPart = "UpperTorso"
		else
			smoothness = 0.07
			aimbotfov = 360
			wallCheck = true
			TargetPart = "UpperTorso"
		end

		if connection then
			connection:Disconnect()
			connection = nil
		end

		connection = RS.RenderStepped:Connect(function()
			if not NinthTrigger then return end
			local target = getClosestEnemy()
			if target then
				local targetPos = target.Position
				local currentPos = camera.CFrame.Position
				local lookAt = CFrame.lookAt(currentPos, targetPos)

				camera.CFrame = camera.CFrame:Lerp(lookAt, smoothness)
			end
		end)

	elseif stat == false and NinthTrigger then
		NinthTrigger = false
		if connection then
			connection:Disconnect()
			connection = nil
		end
	end
end

local function setCheatsValues()
	if not weapons then return end
	for _, weapon in pairs(weapons:GetChildren()) do
		task.wait()
		for _, stats in pairs(weapon:GetDescendants()) do
			for _, v in pairs(stats:GetDescendants()) do
				if v:IsA("NumberValue") then
					if v.Name == "FireRate" and v.Value ~= 0.01 then
						v.Value = 0.01
					end
					if v.Name == "ReloadTime" and v.Value ~= 0.1 then
						v.Value = 0.01
					end
					if v.Name == "Spread" and v.Value ~= 0 then
						v.Value = 0
					end
					if v.Name == "StoredAmmo" then
						v.Value = 9999
					end
					if (v.Name == "DMG" or v.Name == "Damage") and v.Value ~= 9999 then
						v.Value = 9999
					end
					if v.Name == "EquipTime" and v.Value ~= 0 then
						v.Value = 0
					end
					if v.Name == "Tagging" and v.Value ~= 0 then
						v.Value = 0
					end
					if (v.Name == "Range" or v.Name == "RangeModifier") and v.Value ~= 99999 then
						v.Value = 99999
					end
					if (v.Name == "ArmorPenetration" or v.Name == "Penetration") and v.Value ~= 100 then
						v.Value = 100
					end
					if v.Name == "KillAward" and v.Value ~= 0 then
						v.Value = 0
					end
					if v.Name == "Crouch" or v.Name == "Fire" or v.Name == "InitialJump" or v.Name == "Jump" or v.Name == "Ladder" or v.Name == "Land" or v.Name == "Move" or v.Name == "Recoil" or v.Name == "Stand" or v.Name == "Crouched" or v.Name == "RecoveryTime" then
						if v.Value ~= 0 then
							v.Value = 0
						end
					end
				elseif v:IsA("Vector3Value") and v.Name == "Recoil" and v.Value.Magnitude > 0 then
					v.Value = Vector3.new(0,0,0)
				elseif v:IsA("BoolValue") and v.Name == "Auto" and v.Value ~= true then
					v.Value = true
				end
			end
		end
	end
end

local function saveOriginalValues()
	if not weapons then return end
	for _, weapon in pairs(weapons:GetChildren()) do
		task.wait()
		for _, v in pairs(weapon:GetDescendants()) do
			task.wait()
			if v:IsA("NumberValue") or v:IsA("Vector3Value") or v:IsA("BoolValue") then
				local path = v:GetFullName()
				savedValues[path] = {type = v.ClassName, value = v.Value}
			end
		end
	end
end

local function restoreOriginalValues()
	if not weapons then return end
	for _, weapon in pairs(weapons:GetChildren()) do
		for _, v in pairs(weapon:GetDescendants()) do
			if v:IsA("NumberValue") or v:IsA("Vector3Value") or v:IsA("BoolValue") then
				local path = v:GetFullName()
				if savedValues[path] then
					v.Value = savedValues[path].value
				end
			end
		end
	end
end

local function UltraMode(stat)
	if stat == true then
		setCheatsValues()
	else
		restoreOriginalValues()
	end
end

local function Fly(stat)
	local char = game.Players.LocalPlayer.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	local humanoid = char and char:FindFirstChild("Humanoid")
	if not hrp or not humanoid then return end

	if stat == true and fly == false then
		fly = true

		local savedPos = hrp.CFrame

		OriginalJumpPower = humanoid.JumpPower or humanoid.JumpHeight
		OriginalSpeed = humanoid.WalkSpeed

		humanoid.UseJumpPower = false
		humanoid.JumpPower = 0
		humanoid.WalkSpeed = 0

		for _, v in pairs(char:GetDescendants()) do
			if v:IsA("BasePart") then
				v.CanCollide = false
			end
		end

		hrp.CFrame = savedPos
		hrp.Anchored = true

		RS.Heartbeat:Connect(function()
			if fly == true then
				hrp.CFrame = CFrame.new(hrp.Position, camera.CFrame.Position * Vector3.new(1, 0, 1) + Vector3.new(0, hrp.Position.Y, 0))

				local move = Vector3.new(0, 0, 0)
				local cameraLook = camera.CFrame.LookVector * Vector3.new(1, 0, 1)
				local cameraRight = camera.CFrame.RightVector * Vector3.new(1, 0, 1)

				if UIS:IsKeyDown(Enum.KeyCode.W) then
					move = move + (cameraLook * 0.5)
				end
				if UIS:IsKeyDown(Enum.KeyCode.S) then
					move = move + (cameraLook * -0.5)
				end
				if UIS:IsKeyDown(Enum.KeyCode.A) then
					move = move + (cameraRight * -0.5)
				end
				if UIS:IsKeyDown(Enum.KeyCode.D) then
					move = move + (cameraRight * 0.5)
				end
				if UIS:IsKeyDown(Enum.KeyCode.Space) then
					move = move + Vector3.new(0, 0.5, 0)
				end
				if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then
					move = move + Vector3.new(0, -0.5, 0)
				end

				hrp.CFrame = hrp.CFrame + move
			end
		end)

	elseif stat == false and fly == true then
		fly = false
		hrp.Anchored = false
		humanoid.UseJumpPower = true
		humanoid.JumpPower = OriginalJumpPower
		humanoid.WalkSpeed = OriginalSpeed
		humanoid.JumpHeight = OriginalJumpPower

		for _, v in pairs(char:GetDescendants()) do
			if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then
				v.CanCollide = true
			end
		end
	end
end

local function DoubleJump(stat)
	if stat == true then
		CanDoubleJump = true
	else
		CanDoubleJump = false
	end
end

local function WallHack(stat)
	if stat == true then
		if not game.SoundService:FindFirstChild("HighLightFolder") then
			Instance.new("Folder", game.SoundService).Name = "HighLightFolder"
		end

		local highlightFolder = game.SoundService.HighLightFolder

		for _, player in ipairs(game.Players:GetPlayers()) do
			local Character = player.Character
			if Character then
				local head = Character:FindFirstChild("Head")
				if head then
					local teamColor = Color3.new(1, 1, 1)
					if player.Team then
						teamColor = player.Team.TeamColor.Color
					end

					local highlightName = player.Name .. "_Highlight"
					local existingHighlight = highlightFolder:FindFirstChild(highlightName)

					if not existingHighlight then
						local Highlight = Instance.new("Highlight")
						Highlight.Name = highlightName
						Highlight.Parent = highlightFolder
						Highlight.Adornee = Character
						Highlight.FillTransparency = 1
						Highlight.OutlineColor = teamColor
						Highlight.OutlineTransparency = 0
						Highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
					else
						existingHighlight.Adornee = Character
						existingHighlight.OutlineColor = teamColor
					end

					local existingBillboard = head:FindFirstChild("PlayerBillboard")

					if not existingBillboard then
						local BillboardGui = Instance.new("BillboardGui")
						BillboardGui.Name = "PlayerBillboard"
						BillboardGui.Size = UDim2.new(0, 200, 0, 40)
						BillboardGui.ExtentsOffset = Vector3.new(0, 3, 0)
						BillboardGui.AlwaysOnTop = true
						BillboardGui.Adornee = head
						BillboardGui.Parent = head
						BillboardGui.MaxDistance = math.huge

						local MainFrame = Instance.new("Frame")
						MainFrame.Name = "MainFrame"
						MainFrame.Size = UDim2.new(1, 0, 1, 0)
						MainFrame.BackgroundTransparency = 1
						MainFrame.Parent = BillboardGui

						local NameLabel = Instance.new("TextLabel")
						NameLabel.Name = "PlayerNameLabel"
						NameLabel.Size = UDim2.new(0.65, 0, 1, 0)
						NameLabel.Position = UDim2.new(0, 0, 0, 0)
						NameLabel.AnchorPoint = Vector2.new(0, 0)
						NameLabel.BackgroundTransparency = 1
						NameLabel.Text = player.Name
						NameLabel.TextColor3 = teamColor
						NameLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
						NameLabel.TextStrokeTransparency = 0
						NameLabel.TextSize = 12
						NameLabel.Font = Enum.Font.GothamBold
						NameLabel.TextXAlignment = Enum.TextXAlignment.Left
						NameLabel.TextYAlignment = Enum.TextYAlignment.Center
						NameLabel.Parent = MainFrame

						local HealthLabel = Instance.new("TextLabel")
						HealthLabel.Name = "HealthLabel"
						HealthLabel.Size = UDim2.new(0.35, 0, 1, 0)
						HealthLabel.Position = UDim2.new(0.65, 0, 0, 0)
						HealthLabel.AnchorPoint = Vector2.new(0, 0)
						HealthLabel.BackgroundTransparency = 1
						HealthLabel.Text = "100"
						HealthLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
						HealthLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
						HealthLabel.TextStrokeTransparency = 0
						HealthLabel.TextSize = 12
						HealthLabel.Font = Enum.Font.GothamBold
						HealthLabel.TextXAlignment = Enum.TextXAlignment.Right
						HealthLabel.TextYAlignment = Enum.TextYAlignment.Center
						HealthLabel.Parent = MainFrame

						local function updateHealthDisplay()
							local humanoid = Character:FindFirstChild("Humanoid")
							if humanoid and HealthLabel then
								local health = math.floor(humanoid.Health)
								local maxHealth = math.floor(humanoid.MaxHealth)
								HealthLabel.Text = health

								local healthPercent = health / maxHealth
								if healthPercent >= 0.7 then
									HealthLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
								elseif healthPercent >= 0.3 then
									HealthLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
								else
									HealthLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
								end
							end
						end

						local humanoid = Character:FindFirstChild("Humanoid")
						if humanoid then
							humanoid.HealthChanged:Connect(function()
								updateHealthDisplay()
							end)

							humanoid.Died:Connect(function()
								if BillboardGui and BillboardGui.Parent then
									BillboardGui:Destroy()
								end
							end)

							updateHealthDisplay()
						end

					else
						existingBillboard.Adornee = head
						local nameLabel = existingBillboard.MainFrame:FindFirstChild("PlayerNameLabel")
						if nameLabel then
							nameLabel.TextColor3 = teamColor
						end

						local humanoid = Character:FindFirstChild("Humanoid")
						local healthLabel = existingBillboard.MainFrame:FindFirstChild("HealthLabel")
						if humanoid and healthLabel then
							local health = math.floor(humanoid.Health)
							healthLabel.Text = health

							local maxHealth = math.floor(humanoid.MaxHealth)
							local healthPercent = health / maxHealth
							if healthPercent >= 0.7 then
								healthLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
							elseif healthPercent >= 0.3 then
								healthLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
							else
								healthLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
							end
						end
					end
				end
			end
		end

	else
		local highlightFolder = game.SoundService:FindFirstChild("HighLightFolder")
		if highlightFolder then 
			highlightFolder:Destroy() 
		end

		for _, player in ipairs(game.Players:GetPlayers()) do
			if player.Character then
				local head = player.Character:FindFirstChild("Head")
				if head then
					local billboard = head:FindFirstChild("PlayerBillboard")
					if billboard then
						billboard:Destroy()
					end
				end
			end
		end
	end
end

local function SafeZone(stat)
	if stat == true then
		SafeMode = true

		hpriority = true
		local char = game.Players.LocalPlayer.Character
		local hrp = char.HumanoidRootPart
		OriginalPosition = hrp.CFrame

		local TouchedAdded = false

		if TouchedAdded == false then
			TouchedAdded = true
			for _, v in ipairs(char:GetChildren()) do
				if v:IsA("BasePart") then
					v.Touched:Connect(function(hit)
						if SafeMode == true and hit:IsA("BasePart") then
							hit.CanCollide = false
							task.wait(1)
							hit.CanCollide = true
							hrp.Anchored = true
							hpriority = false
						end
					end)
				end
			end
		end
	else
		if hpriority == false then
			SafeMode = false

			local char = game.Players.LocalPlayer.Character
			local hrp = char.HumanoidRootPart
			hrp.Anchored = false

			hrp.CFrame = OriginalPosition
		end
	end
end

local function Noclip(stat)
	local tableuncancollideparts = {}
	if stat == true then
		for _, v in ipairs(game.Players.LocalPlayer.Character:GetChildren()) do
			if v:IsA("BasePart") then
				v.Touched:Connect(function(hit)
					if EleventhTrigger == true then
						if hit:IsA("BasePart") then
							hit.CanCollide = false
							table.insert(tableuncancollideparts, hit)
						end
					else
						for _, hit in ipairs(tableuncancollideparts) do
							hit.CanCollide = true
						end
						tableuncancollideparts = {}
					end
				end)
			end
		end
	else
		for _, hit in ipairs(tableuncancollideparts) do
			hit.CanCollide = true
		end
		tableuncancollideparts = {}
	end
end

local function SpeedHack(stat)
	local Humanoid = game.Players.LocalPlayer.Character:WaitForChild("Humanoid")
	if Humanoid and stat == true then
		task.spawn(function()
			while task.wait(0.01) do
				if SecondTrigger == true then
					Humanoid.WalkSpeed = 50
				end
			end
		end)
	elseif Humanoid and stat == false then
		Humanoid.WalkSpeed = 16
	end
end

UIS.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed or End == true then return end

	if input.KeyCode == Enum.KeyCode.I and Trigger == false then
		local Folder = Instance.new("Folder")
		Folder.Name = "HighLightFolder"
		Folder.Parent = game.SoundService
		WallHack(true)
		Trigger = true
		WallhackLabel.Text = "WallHack (I) <font color='#00FF00'>ON</font>"
	elseif input.KeyCode == Enum.KeyCode.I and Trigger == true then
		Trigger = false
		WallhackLabel.Text = "WallHack (I) <font color='#FF0000'>OFF</font>"
		WallHack(false)
	elseif input.KeyCode == Enum.KeyCode.J and SecondTrigger == false then
		SpeedHack(true)
		Speedhacklabel.Text = "SpeedHack (J) <font color='#00FF00'>ON</font>"
		SecondTrigger = true
	elseif input.KeyCode == Enum.KeyCode.J and SecondTrigger == true then
		SpeedHack(false)
		Speedhacklabel.Text = "SpeedHack (J) <font color='#FF0000'>OFF</font>"
		SecondTrigger = false
	elseif input.KeyCode == Enum.KeyCode.O and EightthTrigger == false then
		--UltraMode(true)
		hvhweapons.Text = "HVH Weapons (O) <font color='#00FF00'>ON</font>"
		EightthTrigger = true
	elseif input.KeyCode == Enum.KeyCode.O and EightthTrigger == true then
		--UltraMode(false)
		hvhweapons.Text = "HVH Weapons (O) <font color='#FF0000'>OFF</font>"
	elseif input.KeyCode == Enum.KeyCode.F8 and NinthTrigger == false then
		Aimbot(true, "rage")
		NinthTrigger = true
		hvhaimbot.Text = "HVH Aimbot (F8) <font color='#00FF00'>ON</font>"
	elseif input.KeyCode == Enum.KeyCode.F8 and NinthTrigger == true then
		Aimbot(false)
		NinthTrigger = false
		hvhaimbot.Text = "HVH Aimbot (F8) <font color='#FF0000'>OFF</font>"
	elseif input.KeyCode == Enum.KeyCode.F10 and NinthTrigger == false then
		Aimbot(true, "legit")
		NinthTrigger = true
		legitaimbotlabel.Text = "Legit Aimbot (F10) <font color='#00FF00'>ON</font>"
	elseif input.KeyCode == Enum.KeyCode.F10 and NinthTrigger == true then
		Aimbot(false)
		NinthTrigger = false
		legitaimbotlabel.Text = "Legit Aimbot (F10) <font color='#FF0000'>OFF</font>"
	elseif input.KeyCode == Enum.KeyCode.F6 and TenthTrigger == false then
		DoubleJump(true)
		TenthTrigger = true
		doublejump.Text = "Double Jump (F6) <font color='#00FF00'>ON</font>"
	elseif input.KeyCode == Enum.KeyCode.F6 and TenthTrigger == true then
		DoubleJump(false)
		TenthTrigger = false
		doublejump.Text = "Double Jump (F6) <font color='#FF0000'>OFF</font>"
	elseif input.KeyCode == Enum.KeyCode.F5 and EleventhTrigger == false then
		Noclip(true)
		EleventhTrigger = true
		nocliplabel.Text = "Noclip (F5) <font color='#00FF00'>ON</font>"
	elseif input.KeyCode == Enum.KeyCode.F5 and EleventhTrigger == true then
		Noclip(false)
		EleventhTrigger = false
		nocliplabel.Text = "Noclip (F5) <font color='#FF0000'>OFF</font>"
	elseif input.KeyCode == Enum.KeyCode.F4 and TwelvethTrigger == false then
		TwelvethTrigger = true
		triggerbotlabel.Text = "Triggerbot (F4) <font color='#00FF00'>ON</font>"
	elseif input.KeyCode == Enum.KeyCode.F4 and TwelvethTrigger == true then
		TwelvethTrigger = false
		triggerbotlabel.Text = "Triggerbot (F4) <font color='#FF0000'>OFF</font>"
	elseif input.KeyCode == Enum.KeyCode.Insert and ScreenGui.Enabled == true then
		ScreenGui.Enabled = false
	elseif input.KeyCode == Enum.KeyCode.K and ThirteenthTrigger == false then
		ThirteenthTrigger = true
		hitboxlabel.Text = "Hitbox (K) <font color='#00FF00'>ON</font>"
		Hitbox(true)
	elseif input.KeyCode == Enum.KeyCode.K and ThirteenthTrigger == true then
		ThirteenthTrigger = false
		hitboxlabel.Text = "Hitbox (K) <font color='#FF0000'>OFF</font>"
		Hitbox(false)
	elseif input.KeyCode == Enum.KeyCode.Insert and ScreenGui.Enabled == false then
		ScreenGui.Enabled = true
	elseif input.KeyCode == Enum.KeyCode.Delete then
		End = true
		game.Players.LocalPlayer.PlayerGui:FindFirstChild("CheatGui"):Destroy()
		if Trigger == true then
			WallHack(false)
		end
		if SecondTrigger == true then
			SpeedHack(false)
		end
		if EightthTrigger == true then
			UltraMode(false)
		end
		if SeventhTrigger == true then
			--Fly(false)
		end
		if SixthTrigger == true then
			SafeZone(false)
		end
	elseif input.KeyCode == Enum.KeyCode.L and SixthTrigger == false then
		SafeZone(true)
		savezonelabel.Text = "SafeZone (L) <font color='#00FF00'>ON</font>"
		SixthTrigger = true
	elseif input.KeyCode == Enum.KeyCode.L and SixthTrigger == true then
		SafeZone(false)
		savezonelabel.Text = "SafeZone (L) <font color='#FF0000'>OFF</font>"
		SixthTrigger = false
	elseif input.KeyCode == Enum.KeyCode.U and SeventhTrigger == false then
		--Fly(true)
		flylabel.Text = "Fly (U) <font color='#00FF00'>ON</font>"
		SeventhTrigger = true
	elseif input.KeyCode == Enum.KeyCode.U and SeventhTrigger == true then
		--Fly(false)
		flylabel.Text = "Fly (U) <font color='#FF0000'>OFF</font>"
		SeventhTrigger = false
	end
end)

UIS.InputBegan:Connect(function(input)
	if input.KeyCode == Enum.KeyCode.Space then
		jumping = true
	end
end)

local function setupPlayerTracking(player)
	player:GetPropertyChangedSignal("Team"):Connect(function()
		if Trigger == true and End == false then
			WallHack(true)
		end
	end)

	player.CharacterAdded:Connect(function()
		if Trigger == true and End == false then
			task.wait(1)
			WallHack(true)
		end
	end)
end

for _, player in ipairs(game.Players:GetPlayers()) do
	setupPlayerTracking(player)
end

game.Players.PlayerAdded:Connect(function(player)
	setupPlayerTracking(player)
	if Trigger == true and End == false then
		task.wait(1)
		WallHack(true)
	end
end)

UIS.InputEnded:Connect(function(input)
	if input.KeyCode == Enum.KeyCode.Space then
		jumping = false
	end
end)


RS.Heartbeat:Connect(function()
	if jumping == true then
		local humanoid = game.Players.LocalPlayer.Character:WaitForChild("Humanoid")
		if humanoid then
			if humanoid.FloorMaterial ~= Enum.Material.Air then
				humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
			else
				if CanDoubleJump == true then
					humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
				end
			end
		end
	end

	if ScreenGui.Enabled == true then
		MouseLockTextButton.Modal = true
	else
		MouseLockTextButton.Modal = false
	end
end)

local function DisableAllFrame()
	Frame.Visible = false
	SecondFrame.Visible = false
	ThirdFrame.Visible = false
	FourthFrame.Visible = false
	FunctionsButton:FindFirstChild("UIStroke").Thickness = 0
	SecondFunctionsButton:FindFirstChild("UIStroke").Thickness = 0
	ParametersButton:FindFirstChild("UIStroke").Thickness = 0
	FAQButton:FindFirstChild("UIStroke").Thickness = 0
end

MouseLock.MouseButton1Click:Connect(function()
	ScreenGui.Enabled = false
end)

FunctionsButton.MouseButton1Click:Connect(function()
	DisableAllFrame()
	Frame.Visible = true
	FunctionsButton:FindFirstChild("UIStroke").Thickness = 0.5
end)

SecondFunctionsButton.MouseButton1Click:Connect(function()
	DisableAllFrame()
	SecondFrame.Visible = true
	SecondFunctionsButton:FindFirstChild("UIStroke").Thickness = 0.5
end)

ParametersButton.MouseButton1Click:Connect(function()
	DisableAllFrame()
	ThirdFrame.Visible = true
	ParametersButton:FindFirstChild("UIStroke").Thickness = 0.5
end)

FAQButton.MouseButton1Click:Connect(function()
	DisableAllFrame()
	FourthFrame.Visible = true
	FAQButton:FindFirstChild("UIStroke").Thickness = 0.5
end)

task.wait(3)
saveOriginalValues()
